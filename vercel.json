{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|static/|favicon.ico|logo192.png|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}